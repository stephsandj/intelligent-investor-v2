# ─────────────────────────────────────────────────────────────────
# Intelligent Investor V2 — Environment Variables
# Copy to .env and fill in all values.
# NEVER commit .env to version control.
#
# Local dev:  start_local.sh reads .env automatically via dashboard_v2.py
# Docker/VPS: deploy.sh generates .env with random secrets on first run
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# DB_PASSWORD is used by docker-compose.yml to start the Postgres
# container AND construct DATABASE_URL inside the app container.
DB_PASSWORD=REPLACE_ME_STRONG_PASSWORD

# For local dev (start_local.sh), set DATABASE_URL directly:
DATABASE_URL=postgresql://ii_user:REPLACE_ME@localhost:5432/intelligentinvestor
# For Docker (docker-compose.yml overrides this to use db:5432):
# DATABASE_URL is set automatically — you only need DB_PASSWORD above.

# ── JWT Authentication ────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Do NOT change after users have active sessions.
JWT_SECRET=REPLACE_ME_64_CHAR_HEX
JWT_ALGORITHM=HS256

# ── Stripe Payments ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

STRIPE_PRICE_STARTER_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_STARTER_YEARLY=price_REPLACE_ME
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_PRO_YEARLY=price_REPLACE_ME
STRIPE_PRICE_ANALYST_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_ANALYST_YEARLY=price_REPLACE_ME
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_ENTERPRISE_YEARLY=price_REPLACE_ME

# ── AI Analysis (Anthropic / Claude) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Stock Data ────────────────────────────────────────────────────
FMP_API_KEY=REPLACE_ME

# ── Email Delivery (Gmail SMTP) ───────────────────────────────────
GMAIL_FROM=your-email@gmail.com
GMAIL_APP_PASSWORD=REPLACE_ME

# ── Application ───────────────────────────────────────────────────
# Local:  APP_BASE_URL=http://localhost:5051
# Docker: APP_BASE_URL=https://your-domain.com  (set by deploy.sh)
APP_BASE_URL=https://your-domain.com
PORT=5050

# ── Admin ─────────────────────────────────────────────────────────
# This email is auto-granted admin on first login
ADMIN_EMAIL=admin@your-domain.com
